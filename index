<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Homy Organic | Organic Store</title>
  <meta name="description" content="Organic skin and hair care store with WhatsApp checkout.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="css/style.css">
</head>
<body>
  <div class="topbar">Free Shipping on Orders Above Rs. 3,000 - COD Available - WhatsApp Orders</div>

  <header class="header">
    <div class="container navbar">
      <a class="logo" href="index.html" aria-label="Homy Organic Home">
        <img src="assets/brand/homy-organic-logo.webp" alt="Homy Organic logo" data-brand-logo>
      </a>

      <nav class="nav" data-nav>
        <a class="nav-link" href="index.html">Home</a>
        <a class="nav-link" href="shop.html">Shop</a>
        <a class="nav-link" href="about.html">About</a>
        <a class="nav-link" href="contact.html">Contact</a>
      </nav>

      <div class="nav-actions">
        <a class="cart-link" href="cart.html">Cart <span class="cart-badge" data-cart-count>0</span></a>
        <button class="menu-button" data-menu-button aria-label="Open menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy reveal">
          <p class="eyebrow">Organic Store</p>
          <h1>Natural glow for <span>skin</span>, hair and everyday confidence.</h1>
          <p>Explore soft, premium care products for smoother-looking skin, fresh hydration, and healthy-looking hair.</p>

          <div class="hero-actions">
            <a class="btn btn-primary" href="shop.html">Shop Collection</a>
            <a class="btn btn-soft" href="#best-sellers">View Best Sellers</a>
          </div>

          <div class="stats-row">
            <div class="stat-card">
              <strong>15</strong>
              <span>Beauty products</span>
            </div>
            <div class="stat-card">
              <strong>COD</strong>
              <span>Easy ordering</span>
            </div>
            <div class="stat-card">
              <strong>4.8â˜…</strong>
              <span>Customer love</span>
            </div>
          </div>
        </div>

        <div class="hero-card reveal">
          <div class="hero-product-card">
            <img src="assets/products/product-2.svg" alt="Anti-Wrinkle Face Serum">
            <div class="floating-info">
              <strong>Soft care</strong>
              <span>Premium organic look</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-sm">
      <div class="container category-grid">
        <a class="category-card reveal" href="shop.html">
          <p class="eyebrow">Skin Care</p>
          <h3>Glow, hydrate and care</h3>
          <p>Face serum, glow cream, toner, cleanser, masks and night care.</p>
          <span class="btn btn-soft">Explore Skin</span>
        </a>

        <a class="category-card reveal" href="shop.html">
          <p class="eyebrow">Hair Care</p>
          <h3>Healthy-looking hair care</h3>
          <p>Hair growth oil, scalp spray, hair mask, serum and grooming care.</p>
          <span class="btn btn-soft">Explore Hair</span>
        </a>

        <a class="category-card reveal" href="checkout.html">
          <p class="eyebrow">Easy Orders</p>
          <h3>Order on WhatsApp</h3>
          <p>Add to cart, fill checkout details, and send your order directly.</p>
          <span class="btn btn-soft">How it Works</span>
        </a>
      </div>
    </section>

    <section class="section" id="best-sellers">
      <div class="container">
        <div class="section-head reveal">
          <div>
            <p class="eyebrow">Best Sellers</p>
            <h2>Customer favorite products</h2>
            <p>Soft, premium product cards with quick add-to-cart and product detail pages.</p>
          </div>
          <a class="btn btn-outline" href="shop.html">View All</a>
        </div>

        <div class="product-grid" data-featured-products></div>
      </div>
    </section>

    <section class="section-sm">
      <div class="container">
        <div class="banner reveal">
          <h2>Light natural and wooden theme built for Homy Organic brands.</h2>
          <p>Modern animations, soft cards, smooth hover effects and a WhatsApp-based checkout for low-budget selling.</p>
          <a class="btn btn-primary" href="shop.html">Start Shopping</a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-head reveal">
          <div>
            <p class="eyebrow">Why Choose Us</p>
            <h2>Simple, natural and customer friendly</h2>
          </div>
        </div>

        <div class="benefit-grid">
          <div class="benefit-card reveal">
            <div class="icon-bubble">HO</div>
            <h3>Organic-inspired</h3>
            <p>Products written with safer beauty-care wording and a clean brand feel.</p>
          </div>

          <div class="benefit-card reveal">
            <div class="icon-bubble">WA</div>
            <h3>WhatsApp orders</h3>
            <p>No backend needed. Checkout opens WhatsApp with complete order details.</p>
          </div>

          <div class="benefit-card reveal">
            <div class="icon-bubble">COD</div>
            <h3>COD ready</h3>
            <p>Cash on Delivery and manual Easypaisa/JazzCash options included.</p>
          </div>

          <div class="benefit-card reveal">
            <div class="icon-bubble">New</div>
            <h3>Modern look</h3>
            <p>Responsive design, smooth animation and premium product presentation.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section-sm">
      <div class="container newsletter reveal">
        <div>
          <h2>Join our beauty list</h2>
          <p>Get product updates, care tips and seasonal offers.</p>
        </div>
        <form data-newsletter-form>
          <input type="email" placeholder="Enter your email">
          <button class="btn btn-primary" type="submit">Subscribe</button>
        </form>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-grid">
      <div>
        <h3 data-brand-name>Homy Organic</h3>
        <p>Organic-inspired skin and hair care made for a soft, confident daily beauty routine.</p>
      </div>

      <div>
        <h4>Shop</h4>
        <a href="shop.html">All Products</a>
        <a href="shop.html">Skin Care</a>
        <a href="shop.html">Hair Care</a>
      </div>

      <div>
        <h4>Support</h4>
        <a href="contact.html">Contact</a>
        <a href="cart.html">Cart</a>
        <a href="checkout.html">Checkout</a>
      </div>

      <div>
        <h4>Follow Us</h4>
        <div class="social-links" data-social-links></div>
        <a data-website-link href="#">Website</a>
      </div>
    </div>

    <div class="container footer-bottom">
      <p>&copy; <span data-current-year>2026</span> Homy Organic. All rights reserved.</p>
    </div>
  </footer>

  <a href="#" class="whatsapp-float" data-whatsapp-float aria-label="Chat on WhatsApp">WA</a>

  <script src="js/products.js"></script>
  <script src="js/main.js"></script>
  <script src="js/home.js"></script>
</body>
</html>


